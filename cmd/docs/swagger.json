                    "type": "string"
                }
            }
        },
        "models.SuccessResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "message": {
                    "type": "string",
                    "example": "account created"
                },
                "status": {
                    "type": "boolean",
                    "example": true
                }
